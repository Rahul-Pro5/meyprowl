# Unicommerce SOAP credentials
UNICOMMERCE_USERNAME=
UNICOMMERCE_PASSWORD=
UNICOMMERCE_FACILITY=01
UNICOMMERCE_USE_PROD=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin key for /api/keys management (set a strong random string)
ADMIN_KEY=
NEXT_PUBLIC_ADMIN_KEY=   # same value — only needed in browser settings page

# Public API key for client-side API calls in sales/reports pages
NEXT_PUBLIC_API_KEY=

# Display environment label in settings page
NEXT_PUBLIC_UC_ENV=staging
